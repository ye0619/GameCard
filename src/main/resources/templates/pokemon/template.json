  "fields": [
    {
      "key": "name",
      "label": "名称",
      "type": "TEXT",
      "required": true,
      "placeholder": "如：炎龙兽"
    },
    {
      "key": "type",
      "label": "属性",
      "type": "ENUM",
      "required": true,
      "defaultValue": "火",
      "options": "[\"火\",\"水\",\"草\",\"电\",\"超能力\",\"格斗\",\"岩石\",\"地面\",\"飞行\",\"虫\",\"毒\",\"一般\",\"幽灵\",\"冰\",\"龙\",\"恶\",\"钢\",\"妖精\"]"
    },
    {
      "key": "hp",
      "label": "HP",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "100",
      "placeholder": "生命值"
    },
    {
      "key": "attack",
      "label": "攻击",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "80",
      "placeholder": "攻击力"
    },
    {
      "key": "defense",
      "label": "防御",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "70",
      "placeholder": "防御力"
    },
    {
      "key": "speed",
      "label": "速度",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "65",
      "placeholder": "速度"
    },
    {
      "key": "spatk",
      "label": "特攻",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "90",
      "placeholder": "特殊攻击"
    },
    {
      "key": "spdef",
      "label": "特防",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "75",
      "placeholder": "特殊防御"
    },
    {
      "key": "cp",
      "label": "CP",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "500",
      "placeholder": "战斗力"
    },
    {
      "key": "level",
      "label": "等级",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "50",
      "placeholder": "Lv."
    },
    {
      "key": "skills",
      "label": "技能",
      "type": "ARRAY",
      "required": false,
      "fields": [
        {
          "key": "name",
          "label": "技能名称",
          "type": "TEXT",
          "required": true,
          "placeholder": "如：火焰吐息"
        }
      ]
    },
    {
      "key": "description",
      "label": "描述",
      "type": "TEXTAREA",
      "required": false,
      "placeholder": "输入图鉴描述..."
    },
    {
      "key": "image",
      "label": "角色图片",
      "type": "IMAGE",
      "required": true
    }
  ],
