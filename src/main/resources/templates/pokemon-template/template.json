  "fields": [
    {
      "key": "name",
      "label": "名称",
      "type": "TEXT",
      "required": true,
      "placeholder": "如：无敌暴龙战士"
    },
    {
      "key": "nature",
      "label": "性格",
      "type": "ENUM",
      "required": true,
      "defaultValue": "暴躁",
      "options": "[\"暴躁\",\"温柔\",\"活泼\",\"体贴\",\"偏激\",\"乐观\",\"沉稳\",\"可靠\",\"随性\",\"平和\",\"优雅\",\"中庸\",\"高尚\",\"高冷\",\"深沉\",\"懦弱\",\"阴郁\",\"呆萌\"]"
    },
    {
      "key": "wisdom",
      "label": "智慧",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "100",
      "placeholder": "智慧"
    },
    {
      "key": "constitution",
      "label": "体质",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "80",
      "placeholder": "体质"
    },
    {
      "key": "perception",
      "label": "感知",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "70",
      "placeholder": "感知"
    },
    {
      "key": "charm",
      "label": "魅力",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "65",
      "placeholder": "魅力"
    },
    {
      "key": "strength",
      "label": "力量",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "90",
      "placeholder": "力量"
    },
    {
      "key": "luck",
      "label": "幸运",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "75",
      "placeholder": "幸运"
    },
    {
      "key": "cp",
      "label": "战斗力",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "500",
      "placeholder": "战斗力"
    },
    {
      "key": "age",
      "label": "年龄",
      "type": "NUMBER",
      "required": false,
      "defaultValue": "50",
      "placeholder": "年龄."
    },
    {
      "key": "skills",
      "label": "技能",
      "type": "ARRAY",
      "required": false,
      "fields": [
        {
          "key": "name",
          "label": "技能名称",
          "type": "TEXT",
          "required": true,
          "placeholder": "如：火焰吐息"
        }
      ]
    },
    {
      "key": "description",
      "label": "描述",
      "type": "TEXTAREA",
      "required": false,
      "placeholder": "输入图鉴描述..."
    },
    {
      "key": "image",
      "label": "角色图片",
      "type": "IMAGE",
      "required": true
    }
  ],
