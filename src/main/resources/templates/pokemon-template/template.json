  "presetIntroductions": [
    {
      "title": "独行侠客",
      "content": "一位游历大陆的独行侠客，身披残破的斗篷，腰间的长剑已陪伴他走过无数个春秋。他话不多，但每一剑都蕴含着多年的历练与沉淀。传闻他曾是某个王国的骑士团长，因不愿参与权力的游戏而选择了流浪。",
      "natureHint": "高冷"
    },
    {
      "title": "远古守护者",
      "content": "来自远古时代的守护者，沉睡千年后被唤醒。他拥有古老的知识和力量，肩负着保护世界平衡的使命。虽然外表看起来威严而沧桑，但内心依然保持着对生命的热爱与敬畏。",
      "natureHint": "深沉"
    },
    {
      "title": "暗夜精灵",
      "content": "生长于幽暗森林的暗夜精灵，拥有与自然沟通的天赋。她身姿轻盈，行动如风，手中的弓箭从不虚发。她守护着森林的秘密，对任何破坏自然平衡的人都毫不留情。",
      "natureHint": "偏激"
    },
    {
      "title": "火焰之子",
      "content": "出生时便被火焰祝福的孩子，体内流淌着灼热的炎之血脉。他性格豪迈直爽，战斗风格如烈火般猛烈。虽然有时会因冲动而陷入困境，但他的热情和勇气总能感染身边的人。",
      "natureHint": "暴躁"
    },
    {
      "title": "深海公主",
      "content": "来自深海国度的人鱼公主，拥有控制水流的神秘力量。她性情温柔如水，待人以诚，但在关键时刻展现出惊人的坚韧。她离开海洋来到陆地，是为了寻找一种能够治愈海洋污染的圣物。",
      "natureHint": "温柔"
    },
    {
      "title": "森林精灵",
      "content": "居住在世界之森中的精灵少女，能与所有生灵交流。她活泼好动，热爱自由，总是在林间欢快地穿梭。她的笑容如春风般温暖，能让最阴郁的心情也变得明朗起来。",
      "natureHint": "活泼"
    },
    {
      "title": "圣殿骑士",
      "content": "身披银色铠甲的圣殿骑士，信仰坚定，举止优雅。他不仅是战场上的利刃，更是民众心中的守护者。他坚信正义必胜，并以身作则地践行着自己的信念。",
      "natureHint": "高尚"
    },
    {
      "title": "流浪剑士",
      "content": "没有过去的流浪剑士，独自走遍天涯海角。他的剑术出神入化，却从不轻易显露。他看似随性不羁，实则心思缜密，总是在暗中保护着那些需要帮助的人。",
      "natureHint": "随性"
    },
    {
      "title": "月光祭司",
      "content": "信奉月神的祭司，在月光的照耀下获得预言与治愈的力量。她平和而睿智，总是以温柔的态度化解纷争。她的预言从未出错，但命运的真相往往比想象中更加复杂。",
      "natureHint": "平和"
    },
    {
      "title": "钢铁巨人",
      "content": "由远古矮人打造的钢铁巨人，原本是守护地下宝库的机械守卫。在漫长岁月中产生了自我意识，开始探索世界。他沉稳可靠，一旦承诺就绝不会违背。",
      "natureHint": "可靠"
    },
    {
      "title": "魅影法师",
      "content": "游走于现实与幻境之间的神秘法师，擅长度操纵 illusions 和心灵魔法。她优雅而危险，言语间带着若即若离的诱惑。没人知道她的真实目的，但所有人都不自觉地被她吸引。",
      "natureHint": "优雅"
    },
    {
      "title": "不灭斗士",
      "content": "从不放弃的斗士，即使身处绝境也依然保持乐观。他相信只要坚持不懈，就没有跨越不了的困难。他的斗志如同不灭的火焰，激励着每一个与他并肩作战的人。",
      "natureHint": "乐观"
    },
    {
      "title": "顽石守护",
      "content": "如山岳般沉稳的守护者，拥有操纵岩石与大地的能力。他不善言辞，但行动永远比言语更有力量。无论遇到什么样的强敌，他都会像顽石一样屹立不倒。",
      "natureHint": "沉稳"
    },
    {
      "title": "冰霜女巫",
      "content": "居住在冰封雪原的孤独女巫，掌握着极寒的冰霜魔法。她外表冷漠如冰，内心却藏着一段炽热的往事。她远离尘世，只为守护那个只有她自己还记得的承诺。",
      "natureHint": "高冷"
    },
    {
      "title": "幸运游侠",
      "content": "被命运女神眷顾的游侠，运气好得令人难以置信。他总能在关键时刻化险为夷，误打误撞地完成各种不可能的任务。虽然看起来大大咧咧，但他的直觉从未出过错。",
      "natureHint": "呆萌"
    }
  ],
